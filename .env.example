# SAM Contract Scout — environment variables
# Copy this file to .env and fill in your credentials.
# The tool runs in demo mode (sample data) if either key is left blank,
# so you can explore the output without signing up for anything.

# SAM.gov public API key — free, requires a sam.gov account
# Get it at: https://sam.gov/profile/details
SAM_API_KEY=

# Anthropic API key
# Get it at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional — override the Claude model used for analysis.
# Defaults to claude-sonnet-4-5 if unset.
# MODEL=claude-sonnet-4-5
