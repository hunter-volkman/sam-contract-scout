{
  "name": "sam-contract-scanner",
  "version": "0.2.0",
  "description": "Scans SAM.gov for government contract opportunities and uses Claude to score them. Outputs a CLI report and optional JSON.",
  "type": "module",
  "main": "src/agent.js",
  "scripts": {
    "start": "node src/agent.js",
    "dev": "node --watch src/agent.js"
  },
  "engines": {
    "node": ">=18.17"
  },
  "keywords": [
    "government-contracting",
    "sam.gov",
    "claude",
    "anthropic",
    "ai-agent",
    "playwright"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.0.0",
    "playwright": "^1.58.2"
  }
}
